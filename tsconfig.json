{
	"extends": "./tsconfig.base.json",
	"compilerOptions": {
		"noEmit": true,
		"paths": {
			"*": ["./*"],
			"@digi4care/the-firm-ai": ["./packages/ai/src/index.ts"],
			"@digi4care/the-firm-ai/oauth": ["./packages/ai/src/oauth.ts"],
			"@digi4care/the-firm-ai/*": ["./packages/ai/src/*.ts", "./packages/ai/src/providers/*.ts"],
			"@digi4care/the-firm-ai/dist/*": ["./packages/ai/src/*"],
			"@digi4care/the-firm-agent-core": ["./packages/agent/src/index.ts"],
			"@digi4care/the-firm-agent-core/*": ["./packages/agent/src/*"],
			"@digi4care/the-firm": ["./packages/coding-agent/src/index.ts"],
			"@digi4care/the-firm/hooks": ["./packages/coding-agent/src/core/hooks/index.ts"],
			"@digi4care/the-firm/*": ["./packages/coding-agent/src/*"],
			"@sinclair/typebox": ["./node_modules/@sinclair/typebox"],
			"@digi4care/the-firm-mom": ["./packages/mom/src/index.ts"],
			"@digi4care/the-firm-mom/*": ["./packages/mom/src/*"],
			"@digi4care/the-firm-pods": ["./packages/pods/src/index.ts"],
			"@digi4care/the-firm-pods/*": ["./packages/pods/src/*"],
			"@digi4care/the-firm-tui": ["./packages/tui/src/index.ts"],
			"@digi4care/the-firm-tui/*": ["./packages/tui/src/*"],
			"@digi4care/the-firm-web-ui": ["./packages/web-ui/src/index.ts"],
			"@digi4care/the-firm-web-ui/*": ["./packages/web-ui/src/*"],
			"@mariozechner/pi-agent-old": ["./packages/agent-old/src/index.ts"],
			"@mariozechner/pi-agent-old/*": ["./packages/agent-old/src/*"]
		}
	},
	"include": ["packages/*/src/**/*", "packages/*/test/**/*", "packages/coding-agent/examples/**/*"],
	"exclude": ["packages/web-ui/**/*", "**/dist/**"]
}
