@startuml
' The Firm organization and runtime hierarchy

title The Firm — Organization, Agent Hierarchy, and Runtime Layers
left to right direction
skinparam backgroundColor white
skinparam shadowing false
skinparam packageStyle rectangle
skinparam defaultTextAlignment center
skinparam ArrowColor #4B5563
skinparam PackageBorderColor #374151
skinparam PackageBackgroundColor #F8FAFC
skinparam RectangleBorderColor #374151
skinparam RectangleBackgroundColor #FFFFFF
skinparam NoteBackgroundColor #FFF7D6
skinparam NoteBorderColor #D6B656
skinparam roundcorner 12

legend right
  == Source basis ==
  * Governance layers: THE_FIRM_GOVERNANCE_AND_COUNCIL_MODEL.md
  * Office roster: THE_FIRM_OPERATING_MODEL.md
  * Runtime roles: THE_FIRM_AGENT_CATALOG.md
  * Lead-role normalization: THE_FIRM_NORMALIZATION_DECISIONS.md
endlegend

package "Layer 1 — Client-facing" as L1 {
  rectangle "client_partner" as client_partner
  rectangle "intake_orchestrator" as intake_orchestrator
  rectangle "engagement_manager" as engagement_manager
}

package "Layer 2 — Office leadership" as L2 {
  rectangle "product_lead" as product_lead
  rectangle "architecture_lead" as architecture_lead
  rectangle "engineering_lead" as engineering_lead
  rectangle "qa_lead" as qa_lead
  rectangle "workflow_governor" as workflow_governor
}

package "Layer 3 — Specialist execution" as L3 {
  package "Product Office" as product_office {
    rectangle "product_strategist" as product_strategist
    rectangle "product_manager" as product_manager
    rectangle "acceptance_designer" as acceptance_designer
  }

  package "Architecture Office" as architecture_office {
    rectangle "context_scout" as context_scout
    rectangle "callsite_auditor" as callsite_auditor
    rectangle "state_flow_mapper" as state_flow_mapper
    rectangle "solution_architect" as solution_architect
    rectangle "verification_planner" as verification_planner
    rectangle "parallelization_planner" as parallelization_planner
  }

  package "Engineering Office" as engineering_office {
    rectangle "frontend_engineer" as frontend_engineer
    rectangle "backend_engineer" as backend_engineer
    rectangle "integration_engineer" as integration_engineer
    rectangle "state_management_engineer" as state_management_engineer
    rectangle "refactor_engineer" as refactor_engineer
    rectangle "test_engineer" as test_engineer
  }

  package "QA & Reliability Office" as qa_office {
    rectangle "qa_verifier" as qa_verifier
    rectangle "regression_reviewer" as regression_reviewer
    rectangle "state_propagation_auditor" as state_propagation_auditor
    rectangle "e2e_strategist" as e2e_strategist
    rectangle "release_reviewer" as release_reviewer
  }

  package "Workflow Operations Office" as workflow_office {
    rectangle "issue_orchestrator" as issue_orchestrator
    rectangle "handoff_coordinator" as handoff_coordinator
    rectangle "state_recorder" as state_recorder
  }
}

package "Layer 4 — Governance / executive" as L4 {
  rectangle "firm_director" as firm_director
  rectangle "architecture_council" as architecture_council
  rectangle "quality_council" as quality_council
  rectangle "engagement_council" as engagement_council
  rectangle "firm_council" as firm_council
}

client_partner --> intake_orchestrator : absorbs client input
intake_orchestrator --> engagement_manager : qualifies and routes
engagement_manager --> product_lead : initiates framed work
engagement_manager --> architecture_lead : requests staffed design path
engagement_manager --> workflow_governor : requires governed execution

product_lead --> product_strategist
product_lead --> product_manager
product_lead --> acceptance_designer

architecture_lead --> context_scout
architecture_lead --> callsite_auditor
architecture_lead --> state_flow_mapper
architecture_lead --> solution_architect
architecture_lead --> verification_planner
architecture_lead --> parallelization_planner

engineering_lead --> frontend_engineer
engineering_lead --> backend_engineer
engineering_lead --> integration_engineer
engineering_lead --> state_management_engineer
engineering_lead --> refactor_engineer
engineering_lead --> test_engineer

qa_lead --> qa_verifier
qa_lead --> regression_reviewer
qa_lead --> state_propagation_auditor
qa_lead --> e2e_strategist
qa_lead --> release_reviewer

workflow_governor --> issue_orchestrator
workflow_governor --> handoff_coordinator
workflow_governor --> state_recorder

product_manager --> context_scout : framed work
acceptance_designer --> solution_architect : acceptance intent
solution_architect --> engineering_lead : design lock
verification_planner --> engineering_lead : proof burden
parallelization_planner --> issue_orchestrator : execution waves
engineering_lead --> qa_verifier : QA entry
qa_verifier --> release_reviewer : verification outcome
workflow_governor ..> qa_verifier : process-valid handoff

firm_director --> firm_council
architecture_lead --> architecture_council
engineering_lead --> architecture_council
qa_lead --> architecture_council
qa_lead --> quality_council
engineering_lead --> quality_council
workflow_governor --> quality_council
client_partner --> engagement_council
engagement_manager --> engagement_council
product_lead --> engagement_council
architecture_lead --> engagement_council
firm_director --> firm_council
workflow_governor --> firm_council
product_lead --> firm_council
architecture_lead --> firm_council
engineering_lead --> firm_council
qa_lead --> firm_council

note bottom of engineering_lead
  Dual-natured role per
  THE_FIRM_NORMALIZATION_DECISIONS.md:
  office lead + runtime delivery coordinator.
end note

note bottom of L1
  The client should not manage the full specialist swarm directly.
  Front-facing roles absorb entropy and route it into governed work.
end note

note bottom of L4
  Councils are escalation structures, not the default execution mode.
end note
@enduml
