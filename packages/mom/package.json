{
  "name": "@digi4care/the-firm-mom",
  "version": "0.0.1",
  "description": "Slack bot that delegates messages to the Firm coding agent",
  "type": "module",
  "bin": {
    "mom": "dist/main.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "CHANGELOG.md"
  ],
  "scripts": {
    "clean": "shx rm -rf dist",
    "build": "tsgo -p tsconfig.build.json && shx chmod +x dist/main.js",
    "dev": "tsgo -p tsconfig.build.json --watch --preserveWatchOutput",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "dependencies": {
    "@anthropic-ai/sandbox-runtime": "^0.0.16",
    "@digi4care/the-firm": "^0.0.1",
    "@digi4care/the-firm-agent-core": "^0.0.1",
    "@digi4care/the-firm-ai": "^0.0.1",
    "@sinclair/typebox": "^0.34.0",
    "@slack/socket-mode": "^2.0.0",
    "@slack/web-api": "^7.0.0",
    "chalk": "^5.6.2",
    "croner": "^9.1.0",
    "diff": "^8.0.2"
  },
  "devDependencies": {
    "@types/diff": "^7.0.2",
    "@types/node": "^24.3.0",
    "typescript": "^5.7.3"
  },
  "keywords": [
    "slack",
    "bot",
    "ai",
    "agent"
  ],
  "author": "digi4care",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/digi4care/the-firm.git",
    "directory": "packages/mom"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
